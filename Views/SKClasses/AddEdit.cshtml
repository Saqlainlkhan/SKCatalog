@model SKCatalog.Models.SKClass
@{
    string title = ViewBag.Action + " Class";
    ViewData["Title"] = title;
    var departments = new List<string>
    {
        "Computer Science",
        "Health Informatica",
        "Match",
        "Chemistry"
    };
}

<h2>@title</h2>

<form asp-action="Edit" method="post">
    <div asp-validation-summary="All" class="text-danger"></div>

    <div class="mb-3">
        <label asp-for="Name" class="form-label">Class Name</label>
        <input asp-for="Name" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Number" class="form-label">Class Number</label>
        <input asp-for="Number" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Department" class="form-label">Department</label>
        <select asp-for="Department" class="form-select">
            <option value="">-- Select Department --</option>
            @foreach (var dept in departments)
            {
                <option value="@dept">@dept</option>
            }
        </select>
    </div>

    <div class="mb-3">
        <label asp-for="Credit" class="form-label">Credit Hour</label>
        <input asp-for="Credit" class="form-control" />
    </div>

    <div class="mb-3">
        <label asp-for="Capacity" class="form-label">Capacity</label>
        <input asp-for="Capacity" class="form-control" />
    </div>

    <input type="hidden" asp-for="CourseId" />

    <button type="submit" class="btn btn-primary">Save</button>
    <a asp-controller="SKClasses" asp-action="Index" class="btn btn-primary">Cancel</a>
</form>
